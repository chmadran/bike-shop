# Neon Postgres (requires pgvector extension)
# Tables: bike_faq (question, answer, region, embedding vector)
#         bike_stock (model_name, category, price_gbp, weight_kg, best_for, spec, warehouse, in_stock, quantity)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Stripe — test mode keys from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Used for Stripe Checkout redirect URLs (optional — dev falls back to your browser origin)
# Must include protocol, e.g. http://localhost:3000 or https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
